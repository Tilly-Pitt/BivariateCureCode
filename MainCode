Functions required to fit the model
```{r functions required to run the EM alogirhtm}
##This is the function for the pdf 
omdbwpdf<-function(x,y,a1,a2,b1,b2, rho){
  x1<-(x/a1)^b1
  y1<-(y/a2)^b2
  ans<-b1*b2*x1*y1/((1-rho)*x*y)*exp(-(x1+y1)/(1-rho))*besselI(2*sqrt(rho*x1*y1)/(1-rho),0)
  return(ans)
}

omdbwsurv<-function(x,y,a1,a2,b1,b2, rho, lg, lg2){
  n<-50 
  x1<-(x/a1)^b1
  y1<-(y/a2)^b2
  k<-0:(n-1)
  coeff<-((rho)^(k+1))/ (k+1)^2
  coeffmat<-matrix(data=rep(coeff, length(x1)),nrow= length(x1), byrow=TRUE)
  term_x <- sapply(lg, function(f) f(x1))
  term_y <- sapply(lg, function(f) f(y1))
  Term <- coeffmat * term_x * term_y
  ans<-exp(-x1-y1)+x1*y1*exp(-x1-y1)*rowSums(Term)
  ans[!is.finite(ans) | ans < 0]<-1e-100
  return(ans)
}

omdbwsdashx<-function(x,y,a1,a2,b1,b2, rho, lg, lg2){
  n<-50 
  x1<-(x/a1)^b1
  y1<-(y/a2)^b2
  k<-0:(n-1)
  coeff<-((rho)^(k+1))/ (k+1)^2
  coeffmat<-matrix(data=rep(coeff, length(x1)),nrow= length(x1), byrow=TRUE)
  lst1 <- sapply(lg, function(f) f(y1))
  lst2 <- sapply(lg, function(f) f(x1))
  lst3 <- sapply(lg2, function(f) f(x1))
  ifelse(is.na(dim(lst3)), lst3 <- cbind(0,length(x1), lst3[1:(n-1)]), lst3 <- cbind(rep(0,length(x1)), lst3[,1:(n-1)]))
  Term <- lst1 * lst2 *coeffmat
  Term2 <- lst3*lst1*coeffmat
  ans<- -b1/x*x1*exp(-x1-y1)+(b1/x-b1*x1/x)*x1*y1*exp(-x1-y1)*rowSums(Term)- b1/x*x1*x1*y1*exp(-x1-y1)*rowSums(Term2)
  ans[!is.finite(ans) | ans >= 0]<--1e-100
  return(ans)
}

##EM algorithm
##E step
opifun<-function(x,y,a1,a2,b1,b2,rho, phi00, phi01, phi10,  idx00,idx01, idx10,idx11, lg, lg2){ 
  phi11<-1-phi00-phi10-phi01
  probs=matrix(data=NA, nrow=length(x), ncol=4)
  dx<-dweibull(x,b1,a1)
  dy<-dweibull(y,b2,a2)
  sx<-1-pweibull(x,b1,a1)
  sy<-1-pweibull(y,b2,a2)
  probs[idx00,4]<-1 ##both observed so both sus
  probs[idx00,1:3]<-0 
  
  if (length(idx01) > 0) { #x obs, y cen
    px<- dx[idx01]
    xvals<- x[idx01]
    yvals<- y[idx01]
    s1 <- vapply(seq_along(xvals), function(i) {
      omdbwsdashx(xvals[i], yvals[i], a1, a2, b1, b2, rho, lg, lg2)
    }, numeric(1))
    denom<-phi10*px-phi11*s1
    p3<-phi10*px/denom
    probs[idx01, 3]<-p3
    probs[idx01, 4]<-1-p3
    probs[idx01, 1:2]<-0
  }
  
  if (length(idx10) > 0) {#x cen, y obs
    py <- dy[idx10]
    xvals <- x[idx10]
    yvals <- y[idx10]
    s2 <- vapply(seq_along(yvals), function(i) {
      omdbwsdashx(yvals[i], xvals[i], a2, a1, b2, b1, rho, lg, lg2)
    }, numeric(1))
    denom<-phi01*py-phi11*s2
    p2<-phi01*py/denom
    probs[idx10, 2]<-p2
    probs[idx10, 4]<-1-p2
    probs[idx10, 1]<-0
    probs[idx10, 3]<-0
  }
  
  if (length(idx11) > 0) { ##both censored
    xvals <- x[idx11]
    yvals <- y[idx11]
    sxv <- sx[idx11]
    syv <- sy[idx11]
    survs <- vapply(seq_along(xvals), function(i) {
      omdbwsurv(xvals[i], yvals[i], a1, a2, b1, b2, rho, lg, lg2)
    }, numeric(1))
    denom <- phi11 * survs + phi10 * sxv + phi01 * syv + phi00
    probs[idx11, 1]<-phi00/denom
    probs[idx11, 2]<-phi01*syv / denom
    probs[idx11, 3]<-phi10*sxv / denom
    probs[idx11, 4]<-1-rowSums(probs[idx11, 1:3])
  }
  return(probs)
}

##This is the q function 
olikelihoodfun<-function(x,y,a1,a2,b1,b2,rho,phi00,phi01,phi10, pi1, pi2, pi3, pi4, idx00,idx01, idx10,idx11, lg, lg2){ 
  phi11<-1-phi00-phi10-phi01
  ans<-c()
  ans[idx00]<-pi4[idx00]*log(phi11*omdbwpdf(x[idx00],y[idx00],a1,a2,b1,b2, rho)) ##both observed, both susceptible
  tryCatch({ans[idx01]<-pi4[idx01]*log(-phi11*omdbwsdashx(x[idx01],y[idx01],a1,a2,b1,b2, rho, lg, lg2))+pi3[idx01]*log(phi10*dweibull(x[idx01],b1,a1))},
           warning=function(w) print(c(a1,a2,b1,b2,rho, phi10, phi01, phi00, phi11)))
  ans[idx10]<-pi4[idx10]*log(-phi11*omdbwsdashx(y[idx10],x[idx10],a1,a2,b1,b2, rho, lg, lg2))+pi2[idx10]*log(phi01*dweibull(y[idx10],b2,a2)) ##cen x, obs y
  ans[idx11]<-pi4[idx11]*log(phi11*omdbwsurv(x[idx11],y[idx11],a1,a2,b1,b2, rho, lg, lg2))+pi3[idx11]*log(phi10*(1-pweibull(x[idx11],b1,a1)))+pi2[idx11]*log(phi01*(1-pweibull(y[idx11],b2,a2)))+pi1[idx11]*log(phi00)
  ans[!is.finite(ans)]<--1000
  if(sum(ans)>0){print('help olike')}
  return(sum(ans))
}

##Observed likelihood:
compobslikefun<-function(x,y,a1,a2,b1,b2,rho,phi00,phi01,phi10, idx00,idx01, idx10,idx11,lg, lg2){
  phi11<-1-phi00-phi10-phi01
  lst<-c()
  lst[idx00]<-log(phi11*omdbwpdf(x[idx00],y[idx00],a1,a2,b1,b2, rho)) ##Both observed
  lst[idx01]<-log(-phi11*omdbwsdashx(x[idx01],y[idx01],a1,a2,b1,b2, rho, lg, lg2)+phi10*dweibull(x[idx01],b1,a1)) ##observed x, cen y
  lst[idx10]<-log(-phi11*omdbwsdashx(y[idx10],x[idx10],a1,a2,b1,b2, rho, lg, lg2)+phi01*dweibull(y[idx10],b1,a1))  ##observed y, cen x
  lst[idx11]<-log(phi11*omdbwsurv(x[idx11],y[idx11],a1,a2,b1,b2, rho, lg, lg2)+phi10*(1-pweibull(x[idx11],b1,a1))+phi01*(1-pweibull(y[idx11],b2,a2))+phi00)
  lst[!is.finite(lst)] <- -1000
  return(sum(lst))
}

onegloglikefun2<-function(paraest, piest, dataset, lg, lg2){ 
  a1<-paraest[1]
  a2<-paraest[2]
  b1<-paraest[3]
  b2<-paraest[4]
  rho<-paraest[5]
  phi00<-exp(paraest[6])/(1+exp(paraest[6]))
  phi01<-1-phi00-exp(paraest[7])*(1-phi00)/(1+exp(paraest[7]))
  phi10<-1-phi00-phi01-exp(paraest[8])*(1-phi00-phi01)/(1+exp(paraest[8]))
  if(phi00<0){phi00<-0}
  if(phi10<0){phi10<-0}
  if(phi01<0){phi01<-0}
  x<-dataset[,1]
  y<-dataset[,2]
  c1<-dataset[,3]
  c2<-dataset[,4]
  pi1<-piest[,1]
  pi2<-piest[,2]
  pi3<-piest[,3]
  pi4<-piest[,4]
  idx00<-which(c1==0 & c2 == 0)
  idx01<-which(c1==0 & c2 == 1)
  idx10<-which(c1==1 & c2 == 0)
  idx11<-which(c1==1 & c2 == 1)
  ans<-olikelihoodfun(x,y,a1,a2,b1,b2,rho,phi00,phi01,phi10, pi1, pi2, pi3, pi4, idx00,idx01, idx10,idx11, lg, lg2)
  return(-ans)
}

##This finds starting parameters for alpha, beta and rho
startingparafun<-function(dataset){
  xnocen<-dataset[which(dataset$cenx==0), 1]
  ynocen<-dataset[which(dataset$ceny==0), 2]
  bothnocen<-dataset[which(dataset$cenx==0 & dataset$ceny==0), 1:2]
  wf<-fitdist(xnocen, "weibull")
  a1<-wf$estimate[2]
  b1<-wf$estimate[1]
  wf<-fitdist(ynocen, "weibull")
  a2<-wf$estimate[2]
  b2<-wf$estimate[1]
  ifelse(length(bothnocen[,1])<2, rho<-0.5, {bothnocen<-cbind(bothnocen$xobs^(1/b1), bothnocen$yobs^(1/b2)); rho<-cor(bothnocen[,1], bothnocen[,2])})
  if(rho< 0){
    rho<-0.001
  }
  if(rho>0.99){
    rho<-0.99
  }
  return(c(a1,a2,b1,b2,rho))
}

emfun<-function(dataset, it, paraest, lg, lg2){ ##The parameters are your original parameter estimates
  k=0
  x<-dataset[,1]
  y<-dataset[,2]
  c1<-dataset[,3]
  c2<-dataset[,4]
  comp<-0
  a1<-paraest[1]
  a2<-paraest[2]
  b1<-paraest[3]
  b2<-paraest[4]
  rho<-paraest[5]
  phi00<-exp(paraest[6])/(1+exp(paraest[6]))
  phi01<-1-phi00-exp(paraest[7])*(1-phi00)/(1+exp(paraest[7]))
  phi10<-1-phi00-phi01-exp(paraest[8])*(1-phi00-phi01)/(1+exp(paraest[8]))
  idx00<-which(c1==0 & c2 == 0)
  idx10<-which(c1==1 & c2 == 0)
  idx01<-which(c1==0 & c2 == 1)
  idx11<-which(c1==1 & c2 == 1)
  comp1<-compobslikefun(x,y,a1,a2,b1,b2,rho,phi00,phi01,phi10, idx00,idx01, idx10,idx11,lg, lg2)
  while (k<it & abs(comp-comp1)> 0.00001 ){
    k=k+1
    piest<- opifun(x,y,a1,a2,b1,b2,rho, phi00, phi01, phi10,  idx00,idx01, idx10,idx11, lg, lg2)
    a<-optim(paraest, fn=onegloglikefun2, piest=piest, dataset=dataset, method="L-BFGS-B", lower=c(0.01,0.01,0.01,0.01,0.1,-Inf,-Inf,-Inf), upper=c(10,10,10,10, 0.99, Inf, Inf, Inf), lg=lg, lg2=lg2)
    paraest<-a$par
    a1<-paraest[1]
    a2<-paraest[2]
    b1<-paraest[3]
    b2<-paraest[4]
    rho<-paraest[5]
    phi00<-exp(paraest[6])/(1+exp(paraest[6]))
    phi01<-1-phi00-exp(paraest[7])*(1-phi00)/(1+exp(paraest[7]))
    phi10<-1-phi00-phi01-exp(paraest[8])*(1-phi00-phi01)/(1+exp(paraest[8]))
    phi11<-1-phi00-phi01-phi10
    comp<-comp1
    comp1<-compobslikefun(x,y,a1,a2,b1,b2,rho,phi00,phi01,phi10, idx00,idx01, idx10,idx11,lg, lg2)
  }
  return(c(a1,a2,b1,b2,rho,phi00,phi01, phi10, phi11))
}


