#For SE
sqrt(var(parabootmat))

##Acceleration parameter
meann<-colMeans(parabootmat)
amat<-c()
for(i in 1:9){
  lstest<-parabootmat[,i]
  upp<-sum((lstest-meann[i])^3)
  downn<-6*sum((parabootmat-meann[i])^2)^(3/2)
  amat[i]<-upp/downn
}

##Bias corrected z
zmat<-c()
for(i in 1:9){
  lstest<-parabootmat[,i]
  inn<-sum(lstest<pointest[i])/replicatesnum
  zmat[i]<-qnorm(inn)
}

zalpha<-qnorm(0.025)
zalpha1<-qnorm(0.975)
lb<-pnorm(zmat+(zmat+zalpha)/(1-amat*(zmat+zalpha)))
ub<-pnorm(zmat+(zmat+zalpha1)/(1-amat*(zmat+zalpha1)))

#The confidence intervals
for(i in 1:9){
  print(quantile(parabootmat[,i], c(lb[i],ub[i])))
}

