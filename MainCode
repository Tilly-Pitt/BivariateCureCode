Function to perform the simulation study
```{r sim study}
wrapemfun<-function(n, rho, a1, a2, b1,b2, simnum, phi00, phi01, phi10, crate, it, lg, lg2){
  mat<-matrix(data=NA, nrow=simnum, ncol=9)
  for (i in 1:simnum){
    print(i)
    dataset<-newdatagen1(a1,a2,b1,b2,n, rho, phi00, phi01, phi10, crate, ftime=5)
    startingpara<-c(startingparafun(dataset),-1.1,0.69,0)
    mat[i,]<-emfun(dataset, it, paraest=startingpara, lg=lg, lg2=lg2)
    wrapmat<-data.frame(mat)
  }
  return(wrapmat)
}

