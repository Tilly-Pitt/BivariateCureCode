This is the real data example using the retinopathy dataset from the survival package. The model is fit and then BCA parametric bootstrap is used to find the 95% confidence intervals
```{r dr example}
retino<-reshape(retinopathy, idvar="id", timevar="trt",direction="wide")
dataset<-reshape(retinopathy, idvar="id", timevar="trt",direction="wide")[,c(6,13,7,14)]
colnames(dataset)[1]="xobs"
colnames(dataset)[3]="cenx"
colnames(dataset)[2]="yobs"
colnames(dataset)[4]="ceny"
dataset[,3]<-1-dataset[,3]
dataset[,4]<-1-dataset[,4]
dataset[,1]<-dataset[,1]/12
dataset[,2]<-dataset[,2]/12

startingpara<-c(startingparafun(dataset),-1.1,0.69,0)
pointest<-emfun(dataset, 100, paraest=startingpara, lg=lg, lg2=lg2)

##parametric bootstrap
replicatesnum<-500
parabootmat<-matrix(data=NA, nrow=500, ncol=9)
for(i in 1:replicatesnum){
  print(i)
  newdataset<-newdatagen1(a1=1.817479, a2=3.902200, b1=1.204794, b2=0.8839339,n=197, rho=0.2885303,
                          phi00=0.2052658,phi01=0.4724022, phi10=9.216729e-05,crate=1.6, ftime=5 )
  startingparaest<-c(startingparafun(newdataset),-1.1,0.69,0)
  parabootmat[i,]<-emfun(dataset, it=500, startingparaest, lg=lg, lg2=lg2)
