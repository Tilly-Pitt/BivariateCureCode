Function to generate a dataset with the desired bivariate cure rate properties.
```{r }
newdatagen1<-function(a1,a2,b1,b2,n, rho, phi00, phi01, phi10, crate, ftime){
  xobs<-c()
  yobs<-c()
  cenx<-c()
  ceny<-c()
  expdata<-rBED(rho=rho, 1,1,n)
  u<-runif(n)
  ctime<-rexp(n, crate)
  centime<-pmin(ctime, ftime) ##Patients are automatically censored after ftime
  idx1<-which(u<phi00) ## cured of both
  idx2<-which(phi00<u & u< (phi00+phi01)) ## Cure of x, sus to y
  idx3<-which(phi00+phi01<u & u<phi00+phi01+phi10) ## Cure of y, sus to x
  idx4<-which(phi00+phi10+phi01<u) ##Sus to both
  
  cenx[idx1]<-1
  ceny[idx1]<-1
  xobs[idx1]<-yobs[idx1]<-centime[idx1]  ## cured of both= both cen

  yobs[idx2]<-a2*expdata[idx2,2]^(1/b2)
  ceny[idx2]<-as.integer(centime[idx2]< yobs[idx2])
  yobs[idx2]<-ifelse(ceny[idx2]==1, centime[idx2], yobs[idx2])
  xobs[idx2]<-centime[idx2] ## Cure of x = cen
  cenx[idx2]<-1
  
  xobs[idx3]<-a1*expdata[idx3,1]^(1/b1)
  cenx[idx3]<-as.integer(centime[idx3]< xobs[idx3])
  xobs[idx3]<-ifelse(cenx[idx3]==1, centime[idx3], xobs[idx3])
  yobs[idx3]<-centime[idx3] ## Cure of y = cen
  ceny[idx3]<-1
  
  xobs[idx4]<-a1*expdata[idx4,1]^(1/b1)
  yobs[idx4]<-a2*expdata[idx4,2]^(1/b2)
  ceny[idx4]<-as.integer(centime[idx4]< yobs[idx4])
  yobs[idx4]<-ifelse(ceny[idx4]==1, centime[idx4], yobs[idx4])
  cenx[idx4]<-as.integer(centime[idx4]< xobs[idx4])
  xobs[idx4]<-ifelse(cenx[idx4]==1, centime[idx4], xobs[idx4])
  return(data.frame(xobs,yobs, cenx, ceny)) ##cenx=1 if censored, 0 if observed
}
